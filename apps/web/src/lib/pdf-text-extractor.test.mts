import assert from "node:assert/strict";
import test from "node:test";

import { extractPdfPages } from "./pdf-text-extractor.ts";

const TWO_PAGE_PDF_BASE64 =
  "";

test("extractPdfPages returns page-level text with page numbers", async () => {
  const pages = await extractPdfPages(Buffer.from(TWO_PAGE_PDF_BASE64, "base64"));

  assert.equal(pages.length, 2);
  assert.equal(pages[0]?.pageNumber, 1);
  assert.match(pages[0]?.text ?? "", /Hello Stage 2/);
  assert.equal(pages[1]?.pageNumber, 2);
  assert.match(pages[1]?.text ?? "", /Second page text/);
});
