NODE_ENV=production
HOSTNAME=0.0.0.0
PORT=3000
AV_OKF_BACKEND=production

DATABASE_URL=postgresql://av_okf:av_okf@postgres:5432/av_okf
REDIS_URL=redis://redis:6379

S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=av-okf
S3_ACCESS_KEY_ID=av_okf_minio
S3_SECRET_ACCESS_KEY=av_okf_minio_secret
S3_FORCE_PATH_STYLE=true

AUTH_SECRET=change-me-before-public-deployment
AUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-before-public-deployment
NEXTAUTH_URL=http://localhost:3000
APP_BASE_URL=http://localhost:3000
AV_OKF_KNOWLEDGE_ROOT=../../knowledge
AV_OKF_KNOWLEDGE_VERSION=0.1.0

AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Local smoke-test login. Keep disabled for any public deployment.
AV_OKF_TEST_AUTH_ENABLED=false
AV_OKF_TEST_AUTH_EMAIL=test@av-okf.local
AV_OKF_TEST_AUTH_PASSWORD=av-okf-test
AV_OKF_TEST_AUTH_NAME=AV-OKF Test User

OPENAI_API_KEY=
RAG_CHUNK_TARGET_TOKENS=800
RAG_CHUNK_MAX_TOKENS=1200
RAG_CHUNK_OVERLAP_TOKENS=120
RAG_EMBEDDING_MAX_TOKENS_PER_DOCUMENT=250000
RAG_EMBEDDING_MAX_TOKENS_PER_WORKSPACE_DAY=1000000
RAG_EMBEDDING_MAX_TOKENS_GLOBAL_DAY=5000000

# Local development can omit AV_OKF_BACKEND=production and continue using
# apps/web/.data as the temporary JSON/filesystem vault.
