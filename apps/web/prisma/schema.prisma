generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String            @id @default(cuid())
  name          String?
  email         String?           @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  memberships   WorkspaceMember[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Workspace {
  id                          String                       @id @default(cuid())
  name                        String
  plan                        String                       @default("Production")
  members                     WorkspaceMember[]
  documents                   Document[]
  extractionJobs              ExtractionJob[]
  topicDiscoveryJobs          TopicDiscoveryJob[]
  knowledgeAuthoringRuns      KnowledgeAuthoringRun[]
  ragIndexJobs                RagIndexJob[]
  topicRecords                TopicRecord[]
  activityEvents              ActivityEvent[]
  llmSetting                  WorkspaceLlmSetting?
  chatSessions                ChatSession[]
  okfConceptLifecycles        OkfConceptLifecycle[]
  knowledgeBundles            KnowledgeBundle[]
  bundleDeletionAudits        BundleDeletionAudit[]
  okfConceptEmbeddings        OkfConceptEmbedding[]
  okfEmbeddingJobs            OkfConceptEmbeddingJob[]
  ragRerankDailyUsage         RagRerankDailyUsage[]
  knowledgeGaps               KnowledgeGap[]
  bulkTopicApprovalRuns       BulkTopicApprovalRun[]
  documentDeletionJobs        DocumentDeletionJob[]
  knowledgeBundleDeletionJobs KnowledgeBundleDeletionJob[]
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
}

model RagRerankDailyUsage {
  id          String    @id @default(cuid())
  workspaceId String
  usageDate   String
  calls       Int       @default(0)
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, usageDate])
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String
  role        String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([workspaceId, userId])
}

model WorkspaceLlmSetting {
  workspaceId     String    @id
  provider        String    @default("anthropic")
  encryptedApiKey String?
  updatedAt       DateTime  @default(now()) @updatedAt
  updatedBy       String?
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Document {
  id                     String                   @id @default(cuid())
  workspaceId            String
  knowledgeBundleId      String?
  title                  String
  fileType               String
  size                   String
  sizeBytes              Int
  status                 String
  tags                   String[]
  updatedLabel           String
  owner                  String
  sourceType             String
  pages                  Int                      @default(0)
  description            String                   @default("")
  subjectFamily          String?
  documentType           String?
  classificationCode     String?
  effectivity            String?
  sourceAuthority        String?
  revision               String?
  deletedAt              DateTime?
  deletedBy              String?
  deleteReason           String?                  @db.Text
  ragStatus              String                   @default("not_indexed")
  ragIndexVersion        Int                      @default(0)
  originalFilename       String?
  mimeType               String
  workspace              Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  knowledgeBundle        KnowledgeBundle?         @relation(fields: [knowledgeBundleId], references: [id], onDelete: SetNull)
  customProperties       DocumentCustomProperty[]
  objects                DocumentObject[]
  extractionJobs         ExtractionJob[]
  topicDiscoveryJobs     TopicDiscoveryJob[]
  knowledgeAuthoringRuns KnowledgeAuthoringRun[]
  ragIndexJobs           RagIndexJob[]
  ragChunks              RagChunk[]
  extractedPages         ExtractedPage[]
  extractionLogs         ExtractionLog[]
  topicRecords           TopicRecord[]
  activityEvents         ActivityEvent[]
  bulkApprovalItems      BulkTopicApprovalItem[]
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt

  @@index([workspaceId, updatedAt])
  @@index([knowledgeBundleId, updatedAt])
}

model KnowledgeBundle {
  id                     String                          @id @default(cuid())
  workspaceId            String
  name                   String
  slug                   String
  description            String                          @default("") @db.Text
  status                 String                          @default("active")
  activeProfileVersionId String?                         @unique
  createdBy              String
  createdAt              DateTime                        @default(now())
  updatedAt              DateTime                        @updatedAt
  workspace              Workspace                       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  activeProfileVersion   KnowledgeBundleProfileVersion?  @relation("ActiveBundleProfile", fields: [activeProfileVersionId], references: [id], onDelete: SetNull)
  profileVersions        KnowledgeBundleProfileVersion[] @relation("BundleProfileVersions")
  documents              Document[]
  topics                 TopicRecord[]
  lifecycles             OkfConceptLifecycle[]
  coverageLinks          OkfConceptChunkLink[]
  primaryChatSessions    ChatSession[]                    @relation("PrimaryChatBundle")
  chatSessionSelections  ChatSessionKnowledgeBundle[]
  relationCandidates     OkfRelationCandidate[]
  relationDiscoveryRuns  OkfRelationDiscoveryRun[]
  authoringRuns          KnowledgeAuthoringRun[]
  conceptEmbeddings      OkfConceptEmbedding[]
  conceptEmbeddingJobs   OkfConceptEmbeddingJob[]
  knowledgeGaps          KnowledgeGap[]
  bulkTopicApprovalRuns  BulkTopicApprovalRun[]
  documentDeletionJobs   DocumentDeletionJob[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, status])
}

model KnowledgeBundleProfileVersion {
  id              String           @id @default(cuid())
  bundleId        String
  version         Int
  status          String           @default("draft")
  templateId      String
  schema          Json
  createdBy       String
  activatedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  bundle          KnowledgeBundle  @relation("BundleProfileVersions", fields: [bundleId], references: [id], onDelete: Cascade)
  activeForBundle KnowledgeBundle? @relation("ActiveBundleProfile")

  @@unique([bundleId, version])
  @@index([bundleId, status])
}

model OkfRelationCandidate {
  id                        String                           @id @default(cuid())
  workspaceId               String
  knowledgeBundleId         String
  sourceFile                String
  targetFile                String
  relation                  String
  reason                    String                           @db.Text
  signals                   Json                             @default("[]")
  status                    String                           @default("pending")
  discoveryRunId            String?
  discoveryVersion          String                           @default("deterministic-v2")
  verificationStatus        String                           @default("legacy")
  verificationProvider      String?
  verificationModel         String?
  verificationRelation      String?
  verificationDirection     String?
  verificationEvidenceQuote String?                          @db.Text
  verificationConfidence    Float?
  verificationRationale     String?                          @db.Text
  verificationError         String?                          @db.Text
  verifierVersion           String?
  sourceContentHash         String?
  targetContentHash         String?
  requestedDirection        String?
  verifiedAt                DateTime?
  reviewedBy                String?
  reviewedAt                DateTime?
  createdAt                 DateTime                         @default(now())
  updatedAt                 DateTime                         @updatedAt
  bundle                    KnowledgeBundle                  @relation(fields: [knowledgeBundleId], references: [id], onDelete: Cascade)
  discoveryRun              OkfRelationDiscoveryRun?         @relation(fields: [discoveryRunId], references: [id], onDelete: SetNull)
  verificationAttempts      OkfRelationVerificationAttempt[]

  @@unique([knowledgeBundleId, sourceFile, targetFile, relation])
  @@index([workspaceId, knowledgeBundleId, status])
  @@index([knowledgeBundleId, verificationStatus])
}

model OkfRelationDiscoveryRun {
  id                String                 @id @default(cuid())
  workspaceId       String
  knowledgeBundleId String
  requestedBy       String
  status            String                 @default("running")
  totalCandidates   Int                    @default(0)
  suppressedCount   Int                    @default(0)
  warningCount      Int                    @default(0)
  queuedCount       Int                    @default(0)
  runningCount      Int                    @default(0)
  confirmedCount    Int                    @default(0)
  filteredCount     Int                    @default(0)
  failedCount       Int                    @default(0)
  startedAt         DateTime               @default(now())
  completedAt       DateTime?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  bundle            KnowledgeBundle        @relation(fields: [knowledgeBundleId], references: [id], onDelete: Cascade)
  candidates        OkfRelationCandidate[]

  @@index([workspaceId, knowledgeBundleId, status])
}

model OkfRelationVerificationAttempt {
  id           String               @id @default(cuid())
  candidateId  String
  provider     String?
  model        String?
  promptSent   String               @db.Text
  rawResponse  String?              @db.Text
  result       Json?
  succeeded    Boolean              @default(false)
  errorMessage String?              @db.Text
  createdAt    DateTime             @default(now())
  candidate    OkfRelationCandidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId, createdAt])
}

model KnowledgeAuthoringRun {
  id                            String                         @id @default(cuid())
  workspaceId                   String
  knowledgeBundleId             String
  documentId                    String
  requestedBy                   String?
  profileVersion                Int                            @default(1)
  automaticTopicApprovalEnabled Boolean                        @default(false)
  status                        String                         @default("queued")
  currentStage                  String                         @default("metadata_discovery")
  completedStages               String[]                       @default([])
  estimatedInputTokens          Int                            @default(0)
  enrichmentCandidateCount      Int                            @default(0)
  validationResults             Json                           @default("[]")
  relationSuggestions           Json                           @default("[]")
  errorCode                     String?
  errorMessage                  String?
  costConfirmedAt               DateTime?
  costConfirmedBy               String?
  startedAt                     DateTime?
  readyAt                       DateTime?
  completedAt                   DateTime?
  createdAt                     DateTime                       @default(now())
  updatedAt                     DateTime                       @updatedAt
  workspace                     Workspace                      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  knowledgeBundle               KnowledgeBundle                @relation(fields: [knowledgeBundleId], references: [id], onDelete: Cascade)
  document                      Document                       @relation(fields: [documentId], references: [id], onDelete: Cascade)
  stageAudits                   KnowledgeAuthoringStageAudit[]
  metadataProposals             DocumentMetadataProposal[]
  automaticApprovalRun          BulkTopicApprovalRun?

  @@index([workspaceId, status, createdAt])
  @@index([documentId, createdAt])
}

model KnowledgeAuthoringStageAudit {
  id           String                @id @default(cuid())
  runId        String
  stage        String
  status       String
  attempt      Int                   @default(1)
  provider     String?
  model        String?
  promptSent   String?               @db.Text
  rawResponse  String?               @db.Text
  errorMessage String?
  startedAt    DateTime              @default(now())
  completedAt  DateTime?
  createdAt    DateTime              @default(now())
  run          KnowledgeAuthoringRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, createdAt])
}

model DocumentMetadataProposal {
  id             String                @id @default(cuid())
  runId          String
  documentId     String
  workspaceId    String
  proposedValues Json
  previousValues Json
  appliedValues  Json
  rationale      Json                  @default("{}")
  provider       String
  model          String
  status         String                @default("applied")
  createdAt      DateTime              @default(now())
  undoneAt       DateTime?
  undoneBy       String?
  run            KnowledgeAuthoringRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, createdAt])
  @@index([documentId, createdAt])
}

model BundleDeletionAudit {
  id             String    @id @default(cuid())
  workspaceId    String
  bundleId       String
  bundleName     String
  deletedBy      String
  deletedAt      DateTime  @default(now())
  deletionCounts Json
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, deletedAt])
}

model KnowledgeBundleDeletionJob {
  id           String    @id @default(cuid())
  workspaceId  String
  bundleId     String    @unique
  bundleName   String
  requestedBy  String
  status       String    @default("queued")
  manifest     Json
  attempts     Int       @default(0)
  errorCode    String?
  errorMessage String?   @db.Text
  queuedAt     DateTime  @default(now())
  startedAt    DateTime?
  completedAt  DateTime?
  updatedAt    DateTime  @updatedAt
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status, queuedAt])
}

model DocumentDeletionJob {
  id                String           @id @default(cuid())
  workspaceId       String
  knowledgeBundleId String?
  documentId        String           @unique
  documentTitle     String
  requestedBy       String
  status            String           @default("queued")
  manifest          Json
  attempts          Int              @default(0)
  errorCode         String?
  errorMessage      String?          @db.Text
  queuedAt          DateTime         @default(now())
  startedAt         DateTime?
  workspace         Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  knowledgeBundle   KnowledgeBundle? @relation(fields: [knowledgeBundleId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status, queuedAt])
  @@index([knowledgeBundleId, status])
}

model DocumentCustomProperty {
  id         String   @id @default(cuid())
  documentId String
  key        String
  value      String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model DocumentObject {
  id          String   @id @default(cuid())
  workspaceId String
  documentId  String
  kind        String
  objectKey   String   @unique
  bucket      String
  contentType String
  sizeBytes   Int
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([workspaceId, documentId, kind])
}

model ExtractionJob {
  id           String    @id @default(cuid())
  workspaceId  String
  documentId   String
  status       String
  attempts     Int       @default(0)
  errorCode    String?
  errorMessage String?
  queuedAt     DateTime  @default(now())
  startedAt    DateTime?
  completedAt  DateTime?
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  document     Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([status, queuedAt])
  @@index([workspaceId, documentId])
}

model TopicDiscoveryJob {
  id                   String                @id @default(cuid())
  workspaceId          String
  documentId           String
  status               String                @default("queued")
  provider             String?
  model                String?
  attempts             Int                   @default(0)
  completedWindows     Int                   @default(0)
  totalWindows         Int                   @default(0)
  estimatedInputTokens Int                   @default(0)
  errorCode            String?
  errorMessage         String?
  queuedAt             DateTime              @default(now())
  startedAt            DateTime?
  completedAt          DateTime?
  workspace            Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  document             Document              @relation(fields: [documentId], references: [id], onDelete: Cascade)
  audits               TopicDiscoveryAudit[]

  @@index([status, queuedAt])
  @@index([workspaceId, documentId, queuedAt])
}

model TopicDiscoveryAudit {
  id            String            @id @default(cuid())
  jobId         String
  stage         String
  windowOrdinal Int?
  provider      String
  model         String
  promptSent    String            @db.Text
  rawResponse   String            @db.Text
  inputTokens   Int               @default(0)
  outputTokens  Int               @default(0)
  succeeded     Boolean
  errorMessage  String?
  createdAt     DateTime          @default(now())
  job           TopicDiscoveryJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, createdAt])
}

model ExtractedPage {
  id          String   @id @default(cuid())
  workspaceId String
  documentId  String
  pageNumber  Int
  text        String   @db.Text
  tables      Json
  imageCount  Int
  charCount   Int
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, pageNumber])
  @@index([workspaceId, documentId])
}

model ExtractionLog {
  id          String   @id @default(cuid())
  workspaceId String
  documentId  String
  jobId       String?
  timestamp   DateTime @default(now())
  level       String
  message     String
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([workspaceId, documentId, timestamp])
}

model RagIndexJob {
  id              String     @id @default(cuid())
  workspaceId     String
  documentId      String
  extractionJobId String?
  status          String
  indexVersion    Int
  tokenEstimate   Int        @default(0)
  attempts        Int        @default(0)
  errorCode       String?
  errorMessage    String?
  queuedAt        DateTime   @default(now())
  startedAt       DateTime?
  completedAt     DateTime?
  workspace       Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  document        Document   @relation(fields: [documentId], references: [id], onDelete: Cascade)
  chunks          RagChunk[]

  @@index([status, queuedAt])
  @@index([workspaceId, documentId, status])
}

model RagChunk {
  id                 String                @id
  workspaceId        String
  documentId         String
  indexJobId         String
  indexVersion       Int
  chunkingStrategyId String?
  chunkOrdinal       Int
  text               String                @db.Text
  contentHash        String
  tokenCount         Int
  pageStart          Int
  pageEnd            Int
  sourcePageNumbers  Int[]
  headingPath        String[]
  reviewStatus       String                @default("raw_extracted")
  sourceType         String                @default("raw_extraction")
  sourceTopicId      String?
  isActive           Boolean               @default(false)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  document           Document              @relation(fields: [documentId], references: [id], onDelete: Cascade)
  indexJob           RagIndexJob           @relation(fields: [indexJobId], references: [id], onDelete: Cascade)
  embedding          RagEmbedding?
  okfConceptLinks    OkfConceptChunkLink[]

  @@unique([documentId, indexVersion, chunkOrdinal])
  @@index([workspaceId, documentId, isActive])
  @@index([workspaceId, documentId, sourceType])
  @@index([workspaceId, sourceType, sourceTopicId])
  @@index([workspaceId, isActive])
  @@index([contentHash])
}

model RagEmbedding {
  id          String                      @id @default(cuid())
  workspaceId String
  chunkId     String                      @unique
  model       String
  dimensions  Int
  tokenCount  Int
  embedding   Unsupported("vector(1536)")
  createdAt   DateTime                    @default(now())
  chunk       RagChunk                    @relation(fields: [chunkId], references: [id], onDelete: Cascade)

  @@index([workspaceId, model])
}

model OkfConceptEmbedding {
  id                String                      @id @default(cuid())
  workspaceId       String
  knowledgeBundleId String
  filePath          String
  contentHash       String
  model             String
  dimensions        Int
  tokenCount        Int
  embedding         Unsupported("vector(1536)")
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt
  workspace         Workspace                   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  knowledgeBundle   KnowledgeBundle             @relation(fields: [knowledgeBundleId], references: [id], onDelete: Cascade)

  @@unique([knowledgeBundleId, filePath])
  @@index([workspaceId, knowledgeBundleId])
  @@index([contentHash])
}

model OkfConceptEmbeddingJob {
  id                String          @id @default(cuid())
  workspaceId       String
  knowledgeBundleId String
  filePath          String
  contentHash       String
  bundleName        String
  status            String          @default("queued")
  tokenEstimate     Int             @default(0)
  attempts          Int             @default(0)
  errorCode         String?
  errorMessage      String?         @db.Text
  queuedAt          DateTime        @default(now())
  startedAt         DateTime?
  completedAt       DateTime?
  workspace         Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  knowledgeBundle   KnowledgeBundle @relation(fields: [knowledgeBundleId], references: [id], onDelete: Cascade)

  @@unique([knowledgeBundleId, filePath, contentHash])
  @@index([status, queuedAt])
  @@index([workspaceId, status])
}

model OkfConceptChunkLink {
  id                String          @id @default(cuid())
  workspaceId       String
  knowledgeBundleId String
  okfConceptId      String
  chunkId           String
  coverageType      String
  source            String          @default("okf_frontmatter")
  syncedAt          DateTime        @default(now())
  chunk             RagChunk        @relation(fields: [chunkId], references: [id], onDelete: Cascade)
  knowledgeBundle   KnowledgeBundle @relation(fields: [knowledgeBundleId], references: [id], onDelete: Cascade)

  @@unique([knowledgeBundleId, okfConceptId, chunkId])
  @@index([workspaceId, chunkId])
}

model OkfConceptLifecycle {
  id                String          @id @default(cuid())
  workspaceId       String
  knowledgeBundleId String
  filePath          String
  topicId           String?
  status            String          @default("active")
  reason            String?         @db.Text
  changedBy         String?
  changedAt         DateTime        @default(now())
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  workspace         Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  knowledgeBundle   KnowledgeBundle @relation(fields: [knowledgeBundleId], references: [id], onDelete: Cascade)

  @@unique([knowledgeBundleId, filePath])
  @@index([workspaceId, status])
  @@index([workspaceId, topicId])
}

model TopicRecord {
  id                        String                  @id @default(cuid())
  workspaceId               String
  knowledgeBundleId         String
  documentId                String
  originalTitle             String
  originalSummary           String
  title                     String
  topicType                 String
  summary                   String
  enrichedTitle             String?
  enrichedSummary           String?
  enrichedBody              String?                 @db.Text
  proposedSourcePageNumbers Int[]                   @default([])
  discoveryMetadata         Json                    @default("{}")
  enrichmentStatus          String                  @default("none")
  approvedContentSource     String?
  approvalMode              String?
  approvedBy                String?
  approvedAt                DateTime?
  editedAt                  DateTime?
  editedBy                  String?
  pageStart                 Int
  pageEnd                   Int
  confidence                String
  reviewStatus              String
  relations                 Json                    @default("[]")
  sourcePageNumbers         Int[]
  exportedFilePath          String?
  bulkApprovalRunId         String?
  okfMetadata               Json                    @default("{}")
  workspace                 Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  knowledgeBundle           KnowledgeBundle         @relation(fields: [knowledgeBundleId], references: [id], onDelete: Cascade)
  document                  Document                @relation(fields: [documentId], references: [id], onDelete: Cascade)
  enrichmentAudits          TopicEnrichmentAudit[]
  bulkApprovalItems         BulkTopicApprovalItem[]
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt

  @@index([workspaceId, documentId])
  @@index([knowledgeBundleId, documentId])
  @@index([bulkApprovalRunId])
}

model BulkTopicApprovalRun {
  id                       String                  @id @default(cuid())
  workspaceId              String
  knowledgeBundleId        String
  requestedBy              String
  mode                     String                  @default("human")
  authoringRunId           String?                 @unique
  status                   String                  @default("awaiting_confirmation")
  estimatedEmbeddingTokens Int                     @default(0)
  confirmedAt              DateTime?
  confirmedBy              String?
  startedAt                DateTime?
  completedAt              DateTime?
  errorCode                String?
  errorMessage             String?
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  workspace                Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  knowledgeBundle          KnowledgeBundle         @relation(fields: [knowledgeBundleId], references: [id], onDelete: Cascade)
  authoringRun             KnowledgeAuthoringRun?  @relation(fields: [authoringRunId], references: [id], onDelete: Cascade)
  items                    BulkTopicApprovalItem[]

  @@index([workspaceId, knowledgeBundleId, createdAt])
  @@index([status, createdAt])
}

model BulkTopicApprovalItem {
  id                       String               @id @default(cuid())
  runId                    String
  workspaceId              String
  knowledgeBundleId        String
  documentId               String
  topicId                  String
  status                   String               @default("pending")
  revisionFingerprint      String
  estimatedEmbeddingTokens Int                  @default(0)
  exportedFilePath         String?
  failureCode              String?
  failureMessage           String?
  retryCount               Int                  @default(0)
  startedAt                DateTime?
  completedAt              DateTime?
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  run                      BulkTopicApprovalRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  document                 Document             @relation(fields: [documentId], references: [id], onDelete: Cascade)
  topic                    TopicRecord          @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([runId, topicId])
  @@index([workspaceId, knowledgeBundleId, status])
  @@index([topicId, status])
}

model TopicEnrichmentAudit {
  id           String      @id @default(cuid())
  topicId      String
  provider     String
  model        String
  promptSent   String      @db.Text
  rawResponse  String      @db.Text
  createdAt    DateTime    @default(now())
  requestedBy  String
  succeeded    Boolean
  errorMessage String?
  topic        TopicRecord @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@index([topicId, createdAt])
}

model ActivityEvent {
  id            String    @id @default(cuid())
  workspaceId   String
  documentId    String?
  label         String
  documentTitle String
  timestamp     String
  status        String
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  document      Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)
  createdAt     DateTime  @default(now())

  @@index([workspaceId, createdAt])
}

model ChatSession {
  id                       String                       @id @default(cuid())
  workspaceId              String
  primaryKnowledgeBundleId String?                      @map("knowledgeBundleId")
  userId                   String
  title                    String                       @default("New chat")
  scopeVersion             Int                          @default(1)
  workspace                Workspace                    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  primaryKnowledgeBundle   KnowledgeBundle?             @relation("PrimaryChatBundle", fields: [primaryKnowledgeBundleId], references: [id], onDelete: SetNull)
  knowledgeBundles         ChatSessionKnowledgeBundle[]
  messages                 ChatMessage[]
  knowledgeGaps            KnowledgeGap[]
  createdAt                DateTime                     @default(now())
  updatedAt                DateTime                     @updatedAt

  @@index([workspaceId, updatedAt])
  @@index([primaryKnowledgeBundleId, updatedAt])
}

model ChatSessionKnowledgeBundle {
  sessionId         String
  knowledgeBundleId String
  position          Int
  selectedBy        String
  selectedAt        DateTime        @default(now())
  session           ChatSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  knowledgeBundle   KnowledgeBundle @relation(fields: [knowledgeBundleId], references: [id], onDelete: Cascade)

  @@id([sessionId, knowledgeBundleId])
  @@unique([sessionId, position])
  @@index([knowledgeBundleId, sessionId])
}

model ChatMessage {
  id                 String        @id @default(cuid())
  workspaceId        String
  sessionId          String
  role               String
  content            String        @db.Text
  citations          Json          @default("[]")
  trace              Json?
  knowledgeBundleIds String[]      @default([])
  scopeVersion       Int           @default(1)
  session            ChatSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  knowledgeGap       KnowledgeGap?
  createdAt          DateTime      @default(now())

  @@index([workspaceId, sessionId, createdAt])
}

model KnowledgeGap {
  id                         String           @id @default(cuid())
  workspaceId                String
  primaryKnowledgeBundleId   String?          @map("knowledgeBundleId")
  searchedKnowledgeBundleIds String[]         @default([])
  chatSessionId              String
  assistantMessageId         String           @unique
  question                   String           @db.Text
  retrievalQuery             String           @db.Text
  route                      String
  finalEvidenceStatus        String           @default("no_evidence")
  reason                     String           @db.Text
  searchedSources            String[]
  status                     String           @default("open")
  workspace                  Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  primaryKnowledgeBundle     KnowledgeBundle? @relation(fields: [primaryKnowledgeBundleId], references: [id], onDelete: SetNull)
  chatSession                ChatSession      @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)
  assistantMessage           ChatMessage      @relation(fields: [assistantMessageId], references: [id], onDelete: Cascade)
  createdAt                  DateTime         @default(now())
  updatedAt                  DateTime         @updatedAt

  @@index([workspaceId, primaryKnowledgeBundleId, status, createdAt])
}
